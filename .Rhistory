) %>%
rename(snapshot_date = first_seen) %>%
arrange(snapshot_date)
fact_loc_compliance_trend_mtd_cumulative <- daily_new %>%
mutate(
loc_mtd_cum = cumsum(loc_new),
loc_mtd_with_wo_cum = cumsum(loc_new_with_wo),
loc_mtd_without_wo_cum = loc_mtd_cum - loc_mtd_with_wo_cum,
ops_compliance_rate_cum = ifelse(loc_mtd_cum > 0, loc_mtd_with_wo_cum / loc_mtd_cum, 0),
as_of_date = as_of_date
)
}
write_csv(fact_loc_compliance_trend_mtd_cumulative,
file.path(mart_ops_path, "fact_loc_compliance_trend_mtd_cumulative.csv"))
# =====================================================
# LOC revenue (MTD) from sales_invoice$Item
# =====================================================
fact_loc_revenue_mtd <- tibble(
as_of_date = as_of_date,
LOCFileNumber = character(),
loc_revenue_idr = double(),
revenue_line_count = integer()
)
if (nrow(sales_invoice_mtd) > 0 && "Item" %in% names(sales_invoice_mtd)) {
inv_lines <- sales_invoice_mtd %>% tidyr::unnest(Item, names_sep = "__")
required_cols <- c("Item__FileNumber", "Item__DetailQuantity", "Item__DetailRate")
if (all(required_cols %in% names(inv_lines))) {
fact_loc_revenue_mtd <- inv_lines %>%
transmute(
as_of_date = as_of_date,
LOCFileNumber = as.character(Item__FileNumber),
DetailQuantity = suppressWarnings(as.numeric(Item__DetailQuantity)),
DetailRate = suppressWarnings(as.numeric(Item__DetailRate)),
line_revenue_idr = DetailQuantity * DetailRate
) %>%
filter(!is.na(LOCFileNumber)) %>%
group_by(LOCFileNumber) %>%
summarise(
as_of_date = first(as_of_date),
loc_revenue_idr = sum(line_revenue_idr, na.rm = TRUE),
revenue_line_count = n(),
.groups = "drop"
)
}
}
write_csv(fact_loc_revenue_mtd, file.path(mart_ops_path, "fact_loc_revenue_mtd.csv"))
# =====================================================
# KPI summary (MTD)
# =====================================================
kpi_loc_compliance_mtd <- tibble()
if (nrow(fact_loc_compliance_detail_mtd) > 0) {
detail_with_rev <- fact_loc_compliance_detail_mtd %>%
left_join(fact_loc_revenue_mtd %>% select(LOCFileNumber, loc_revenue_idr), by = "LOCFileNumber")
kpi_loc_compliance_mtd <- detail_with_rev %>%
summarise(
as_of_date = as_of_date,
period = "mtd",
period_start = start_m,
period_end = month_anchor,
loc_total = n(),
loc_with_wo = sum(has_wo_flag),
loc_without_wo = loc_total - loc_with_wo,
ops_compliance_rate = ifelse(loc_total > 0, loc_with_wo / loc_total, 0),
loc_revenue_total_idr = sum(loc_revenue_idr, na.rm = TRUE),
loc_revenue_without_wo_idr = sum(loc_revenue_idr[has_wo_flag == 0], na.rm = TRUE),
loc_revenue_coverage_loc_count = sum(!is.na(loc_revenue_idr))
)
}
write_csv(kpi_loc_compliance_mtd, file.path(mart_ops_path, "kpi_loc_compliance_mtd.csv"))
# =====================================================
# Historical compliance (pre-month) counts only
# =====================================================
fact_loc_compliance_detail_hist <- fact_loc_compliance_detail_mtd %>%
filter(!is.na(OrderDate) & OrderDate < start_m)
write_csv(fact_loc_compliance_detail_hist, file.path(mart_ops_path, "fact_loc_compliance_detail_hist.csv"))
fact_loc_compliance_daily_by_orderdate_hist <- fact_loc_compliance_detail_hist %>%
group_by(OrderDate) %>%
summarise(
loc_total = n(),
loc_with_wo = sum(has_wo_flag),
loc_without_wo = loc_total - loc_with_wo,
ops_compliance_rate = ifelse(loc_total > 0, loc_with_wo / loc_total, 0),
as_of_date = as_of_date,
.groups = "drop"
) %>%
arrange(OrderDate)
write_csv(fact_loc_compliance_daily_by_orderdate_hist,
file.path(mart_ops_path, "fact_loc_compliance_daily_by_orderdate_hist.csv"))
kpi_loc_compliance_hist <- tibble(
as_of_date = as_of_date,
period = "pre_month",
period_start = ifelse(nrow(fact_loc_compliance_detail_hist)>0, min(fact_loc_compliance_detail_hist$OrderDate), NA),
period_end = start_m - 1,
loc_total = nrow(fact_loc_compliance_detail_hist),
loc_with_wo = sum(fact_loc_compliance_detail_hist$has_wo_flag),
loc_without_wo = nrow(fact_loc_compliance_detail_hist) - sum(fact_loc_compliance_detail_hist$has_wo_flag),
ops_compliance_rate = ifelse(nrow(fact_loc_compliance_detail_hist)>0,
sum(fact_loc_compliance_detail_hist$has_wo_flag)/nrow(fact_loc_compliance_detail_hist), 0)
)
write_csv(kpi_loc_compliance_hist, file.path(mart_ops_path, "kpi_loc_compliance_hist.csv"))
# =====================================================
# TRUCK UTILIZATION (IMPORTANT: guarded naming)
# =====================================================
fact_truck_utilization_plate_daily <- tibble()
if (nrow(truck_pos_mtd) > 0) {
tp <- truck_pos_mtd %>%
mutate(
Date = snapshot_date,
TruckType = ifelse(is.na(TruckType) | TruckType == "", "UNKNOWN", as.character(TruckType)),
OrderUuid_chr = trimws(as.character(OrderUuid)),
LoadingUuid_chr = trimws(as.character(LoadingUuid)),
DeliveryUuid_chr = trimws(as.character(DeliveryUuid)),
productive_hit = ifelse(
(!is.na(OrderUuid_chr) & OrderUuid_chr != "") |
(!is.na(LoadingUuid_chr) & LoadingUuid_chr != "") |
(!is.na(DeliveryUuid_chr) & DeliveryUuid_chr != ""),
1L, 0L
),
GpsTimestamp_chr = as.character(GpsTimestamp)
)
fact_truck_utilization_plate_daily <- tp %>%
group_by(Date, TruckPlate, TruckType) %>%
summarise(
ping_count = n(),
last_gps_ts = suppressWarnings(max(GpsTimestamp_chr, na.rm = TRUE)),
productive_flag = ifelse(sum(productive_hit) > 0, 1L, 0L),
idle_flag = ifelse(productive_flag == 1L, 0L, 1L),
as_of_date = as_of_date,
.groups = "drop"
) %>%
select(as_of_date, Date, TruckPlate, TruckType, ping_count, last_gps_ts, productive_flag, idle_flag)
}
# Conflicts check
trucktype_conflict <- fact_truck_utilization_plate_daily %>%
count(Date, TruckPlate) %>%
filter(n > 1)
cat("TruckType conflicts (same plate multiple types in same day): ", nrow(trucktype_conflict), "\n", sep = "")
write_csv(fact_truck_utilization_plate_daily, file.path(mart_ops_path, "fact_truck_utilization_daily.csv"))
# ---- TRUE summaries ----
fact_truck_utilization_summary_daily <- tibble()
fact_truck_utilization_summary_daily_by_type <- tibble()
if (nrow(fact_truck_utilization_plate_daily) > 0) {
fact_truck_utilization_summary_daily <- fact_truck_utilization_plate_daily %>%
ungroup() %>%
group_by(Date) %>%
summarise(
truck_total = n_distinct(TruckPlate),
truck_productive = sum(productive_flag, na.rm = TRUE),
truck_idle = sum(idle_flag, na.rm = TRUE),
utilization_rate = ifelse(truck_total > 0, truck_productive / truck_total, 0),
as_of_date = as_of_date,
.groups = "drop"
) %>%
arrange(Date)
fact_truck_utilization_summary_daily_by_type <- fact_truck_utilization_plate_daily %>%
ungroup() %>%
group_by(Date, TruckType) %>%
summarise(
truck_total = n_distinct(TruckPlate),
truck_productive = sum(productive_flag, na.rm = TRUE),
truck_idle = sum(idle_flag, na.rm = TRUE),
utilization_rate = ifelse(truck_total > 0, truck_productive / truck_total, 0),
as_of_date = as_of_date,
.groups = "drop"
) %>%
arrange(Date, TruckType)
# ---- Guardrails ----
expected_days <- n_distinct(fact_truck_utilization_plate_daily$Date)
if (nrow(fact_truck_utilization_summary_daily) != expected_days) {
stop("TRUCK SUMMARY ERROR: summary_daily rows=", nrow(fact_truck_utilization_summary_daily),
" but expected_days=", expected_days,
". This means summary_daily is not aggregated at Date grain.")
}
}
# =====================================================
# 03_build_mart_ops.R
# FINAL STABLE VERSION
# =====================================================
rm(list = ls())
library(jsonlite)
library(dplyr)
library(tidyr)
library(lubridate)
library(readr)
library(tibble)
# -----------------------------------------------------
# Paths
# -----------------------------------------------------
base_path <- "D:/FKS/14. Visibility"
raw_path  <- file.path(base_path, "data/raw")
mart_ops_path <- file.path(base_path, "data/mart/ops")
audit_path <- file.path(base_path, "data/audit")
dir.create(mart_ops_path, recursive = TRUE, showWarnings = FALSE)
dir.create(audit_path, recursive = TRUE, showWarnings = FALSE)
as_of_date <- as.Date(Sys.time())
# -----------------------------------------------------
# Helpers
# -----------------------------------------------------
list_snapshot_folders <- function(path) {
dirs <- list.dirs(path, recursive = FALSE, full.names = TRUE)
tibble(folder = dirs,
date = suppressWarnings(as.Date(basename(dirs)))) %>%
filter(!is.na(date)) %>%
arrange(date)
}
safe_read_json_data <- function(path) {
if (!file.exists(path)) return(tibble())
txt <- paste(readLines(path, warn = FALSE), collapse = "")
txt <- trimws(txt)
if (nchar(txt) == 0 || txt %in% c("NA","null")) return(tibble())
parsed <- tryCatch(fromJSON(txt, flatten = TRUE), error = function(e) NULL)
if (is.null(parsed) || !"data" %in% names(parsed)) return(tibble())
as_tibble(parsed$data)
}
read_dataset_multi <- function(folders, filename) {
out <- list()
for (f in folders) {
d <- safe_read_json_data(file.path(f, filename))
if (nrow(d) > 0) {
d <- d %>% mutate(snapshot_date = as.Date(basename(f)))
out[[length(out)+1]] <- d
}
}
if (length(out)==0) return(tibble())
bind_rows(out)
}
# -----------------------------------------------------
# Month logic
# -----------------------------------------------------
all_folders <- list_snapshot_folders(raw_path)
latest_folder <- tail(all_folders$folder,1)
month_anchor <- tail(all_folders$date,1)
start_m <- as.Date(format(month_anchor,"%Y-%m-01"))
mtd_folders <- all_folders %>%
filter(date >= start_m & date <= month_anchor) %>%
pull(folder)
cat("Month anchor:", month_anchor,"\n")
cat("MTD folders:", length(mtd_folders),"\n")
# -----------------------------------------------------
# Load datasets (MTD)
# -----------------------------------------------------
road_order_mtd    <- read_dataset_multi(mtd_folders,"road_order.json")
sales_order_mtd   <- read_dataset_multi(mtd_folders,"sales_order.json")
sales_invoice_mtd <- read_dataset_multi(mtd_folders,"sales_invoice.json")
truck_pos_mtd     <- read_dataset_multi(mtd_folders,"truck_position.json")
# =====================================================
# BRIDGE WO -> LOC
# =====================================================
bridge_wo_loc_mtd <- tibble()
if (nrow(sales_order_mtd)>0 && "OrderDetail" %in% names(sales_order_mtd)) {
bridge_wo_loc_mtd <- sales_order_mtd %>%
select(WOFileNumber = FileNumber, OrderDetail, snapshot_date) %>%
unnest(OrderDetail, names_sep="__") %>%
transmute(
WOFileNumber = WOFileNumber,
LOCFileNumber = OrderDetail__FileNumber,
snapshot_date = snapshot_date
) %>%
filter(!is.na(LOCFileNumber)) %>%
distinct()
}
# =====================================================
# LOC EXECUTION DETAIL (DEDUP)
# =====================================================
fact_loc_execution_detail_mtd <- tibble()
if (nrow(road_order_mtd)>0) {
tmp <- road_order_mtd %>%
mutate(
LOCFileNumber = FileNumber,
OrderDate = suppressWarnings(as.Date(OrderDate)),
closed_flag = ifelse(Closed=="Y",1L,0L),
deleted_flag = ifelse(Deleted=="Y",1L,0L)
)
fact_loc_execution_detail_mtd <- tmp %>%
arrange(LOCFileNumber, desc(snapshot_date)) %>%
group_by(LOCFileNumber) %>%
slice(1) %>%
ungroup()
}
write_csv(fact_loc_execution_detail_mtd,
file.path(mart_ops_path,"fact_loc_execution_detail_mtd.csv"))
# =====================================================
# LOC COMPLIANCE DETAIL
# =====================================================
fact_loc_compliance_detail_mtd <- tibble()
if (nrow(fact_loc_execution_detail_mtd)>0) {
loc_to_wo <- bridge_wo_loc_mtd %>%
select(LOCFileNumber, WOFileNumber) %>%
distinct()
fact_loc_compliance_detail_mtd <- fact_loc_execution_detail_mtd %>%
left_join(loc_to_wo, by="LOCFileNumber") %>%
group_by(LOCFileNumber) %>%
summarise(
OrderDate = first(OrderDate),
CustomerName = first(CustomerName),
snapshot_date = first(snapshot_date),
wo_count = n_distinct(WOFileNumber[!is.na(WOFileNumber)]),
has_wo_flag = ifelse(wo_count>0,1L,0L),
.groups="drop"
)
}
write_csv(fact_loc_compliance_detail_mtd,
file.path(mart_ops_path,"fact_loc_compliance_detail_mtd.csv"))
# =====================================================
# CUMULATIVE MTD COMPLIANCE TREND
# =====================================================
fact_loc_compliance_trend_mtd_cumulative <- tibble()
if (nrow(road_order_mtd)>0) {
loc_first_seen <- road_order_mtd %>%
transmute(LOCFileNumber=FileNumber,
snapshot_date=snapshot_date) %>%
group_by(LOCFileNumber) %>%
summarise(first_seen=min(snapshot_date),.groups="drop")
loc_first_seen <- loc_first_seen %>%
left_join(fact_loc_compliance_detail_mtd %>%
select(LOCFileNumber,has_wo_flag),
by="LOCFileNumber") %>%
mutate(has_wo_flag=ifelse(is.na(has_wo_flag),0L,has_wo_flag))
daily_new <- loc_first_seen %>%
group_by(first_seen) %>%
summarise(
loc_new=n(),
loc_new_with_wo=sum(has_wo_flag),
.groups="drop"
) %>%
arrange(first_seen)
fact_loc_compliance_trend_mtd_cumulative <- daily_new %>%
mutate(
loc_mtd_cum=cumsum(loc_new),
loc_mtd_with_wo_cum=cumsum(loc_new_with_wo),
loc_mtd_without_wo_cum=loc_mtd_cum-loc_mtd_with_wo_cum,
ops_compliance_rate_cum=loc_mtd_with_wo_cum/loc_mtd_cum
)
}
write_csv(fact_loc_compliance_trend_mtd_cumulative,
file.path(mart_ops_path,"fact_loc_compliance_trend_mtd_cumulative.csv"))
# =====================================================
# LOC REVENUE FROM sales_invoice$Item
# =====================================================
fact_loc_revenue_mtd <- tibble()
if (nrow(sales_invoice_mtd)>0 && "Item" %in% names(sales_invoice_mtd)) {
inv_lines <- sales_invoice_mtd %>%
unnest(Item,names_sep="__")
required_cols <- c("Item__FileNumber",
"Item__DetailQuantity",
"Item__DetailRate")
if (all(required_cols %in% names(inv_lines))) {
fact_loc_revenue_mtd <- inv_lines %>%
transmute(
LOCFileNumber=as.character(Item__FileNumber),
qty=as.numeric(Item__DetailQuantity),
rate=as.numeric(Item__DetailRate),
line_revenue=qty*rate
) %>%
group_by(LOCFileNumber) %>%
summarise(
loc_revenue_idr=sum(line_revenue,na.rm=TRUE),
.groups="drop"
)
}
}
write_csv(fact_loc_revenue_mtd,
file.path(mart_ops_path,"fact_loc_revenue_mtd.csv"))
# =====================================================
# KPI MTD SUMMARY
# =====================================================
kpi_loc_compliance_mtd <- tibble()
if (nrow(fact_loc_compliance_detail_mtd)>0) {
detail_with_rev <- fact_loc_compliance_detail_mtd %>%
left_join(fact_loc_revenue_mtd,by="LOCFileNumber")
kpi_loc_compliance_mtd <- detail_with_rev %>%
summarise(
period="mtd",
period_start=start_m,
period_end=month_anchor,
loc_total=n(),
loc_with_wo=sum(has_wo_flag),
loc_without_wo=loc_total-loc_with_wo,
ops_compliance_rate=loc_with_wo/loc_total,
loc_revenue_total_idr=sum(loc_revenue_idr,na.rm=TRUE),
loc_revenue_without_wo_idr=sum(loc_revenue_idr[has_wo_flag==0],na.rm=TRUE)
)
}
write_csv(kpi_loc_compliance_mtd,
file.path(mart_ops_path,"kpi_loc_compliance_mtd.csv"))
# =====================================================
# HISTORICAL (OrderDate < start_m)
# =====================================================
fact_loc_compliance_detail_hist <- fact_loc_compliance_detail_mtd %>%
filter(!is.na(OrderDate) & OrderDate < start_m)
write_csv(fact_loc_compliance_detail_hist,
file.path(mart_ops_path,"fact_loc_compliance_detail_hist.csv"))
# =====================================================
# TRUCK UTILIZATION (PLATE LEVEL)
# =====================================================
fact_truck_utilization_plate_daily <- tibble()
if (nrow(truck_pos_mtd)>0) {
tp <- truck_pos_mtd %>%
mutate(
Date=snapshot_date,
TruckType=ifelse(is.na(TruckType)|TruckType=="","UNKNOWN",TruckType),
productive_hit=ifelse(
(!is.na(OrderUuid)&OrderUuid!="")|
(!is.na(LoadingUuid)&LoadingUuid!="")|
(!is.na(DeliveryUuid)&DeliveryUuid!=""),
1L,0L)
)
fact_truck_utilization_plate_daily <- tp %>%
group_by(Date,TruckPlate,TruckType) %>%
summarise(
productive_flag=ifelse(sum(productive_hit)>0,1L,0L),
idle_flag=ifelse(productive_flag==1L,0L,1L),
.groups="drop"
)
}
write_csv(fact_truck_utilization_plate_daily,
file.path(mart_ops_path,"fact_truck_utilization_daily.csv"))
# =====================================================
# TRUCK SUMMARY (SAFE)
# =====================================================
fact_truck_utilization_summary_daily <- fact_truck_utilization_plate_daily %>%
distinct(Date,TruckPlate,productive_flag,idle_flag) %>%
group_by(Date) %>%
summarise(
truck_total=n(),
truck_productive=sum(productive_flag),
truck_idle=sum(idle_flag),
utilization_rate=truck_productive/truck_total,
.groups="drop"
)
fact_truck_utilization_summary_daily_by_type <- fact_truck_utilization_plate_daily %>%
distinct(Date,TruckType,TruckPlate,productive_flag,idle_flag) %>%
group_by(Date,TruckType) %>%
summarise(
truck_total=n(),
truck_productive=sum(productive_flag),
truck_idle=sum(idle_flag),
utilization_rate=truck_productive/truck_total,
.groups="drop"
)
write_csv(fact_truck_utilization_summary_daily,
file.path(mart_ops_path,"fact_truck_utilization_summary_daily.csv"))
write_csv(fact_truck_utilization_summary_daily_by_type,
file.path(mart_ops_path,"fact_truck_utilization_summary_daily_by_type.csv"))
# =====================================================
# SANITY
# =====================================================
cat("✅ Ops mart build completed.\n")
cat("Truck summary days:",nrow(fact_truck_utilization_summary_daily),"\n")
nrow(fact_truck_utilization_summary_daily)
unique(fact_truck_utilization_summary_daily$Date)
library(ggplot2)
library(dplyr)
library(scales)
truck_plot_df <- fact_truck_utilization_summary_daily_by_type %>%
mutate(
productive_pct = ifelse(truck_total > 0, truck_productive / truck_total, 0),
idle_pct = ifelse(truck_total > 0, truck_idle / truck_total, 0)
) %>%
select(Date, TruckType, truck_productive, truck_idle,
productive_pct, idle_pct) %>%
pivot_longer(
cols = c(truck_productive, truck_idle),
names_to = "status",
values_to = "truck_count"
) %>%
mutate(
status = recode(status,
truck_productive = "Productive",
truck_idle = "Idle"),
pct = ifelse(status == "Productive",
productive_pct,
idle_pct),
label = paste0(truck_count, "\n(", percent(pct, accuracy = 1), ")")
)
p_truck_util <- ggplot(truck_plot_df,
aes(x = Date,
y = truck_count,
fill = status)) +
geom_col(width = 0.7) +
geom_text(aes(label = label),
position = position_stack(vjust = 0.5),
size = 3.5,
color = "white",
fontface = "bold") +
facet_wrap(~ TruckType, scales = "free_y") +
scale_fill_manual(values = c(
"Productive" = "#1F77B4",   # Blue
"Idle" = "#E15759"          # Red
)) +
scale_y_continuous(expand = expansion(mult = c(0, 0.05))) +
labs(
title = "Truck Utilization (MTD)",
subtitle = "Productive vs Idle Trucks per Snapshot Date",
x = "Date",
y = "Number of Trucks",
fill = ""
) +
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(face = "bold", size = 14),
plot.subtitle = element_text(size = 11),
legend.position = "top",
strip.text = element_text(face = "bold")
)
print(p_truck_util)
